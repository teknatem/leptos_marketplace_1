#!/bin/sh
# Auto-regenerate ARCHITECTURE.md when code that feeds it changes.
# Versioned hook — enabled via:  git config core.hooksPath tools/hooks
# Runs only if staged files touch the sources the generator reads, so most
# commits pay no cost. Regenerated ARCHITECTURE.md is staged into the commit.

staged=$(git diff --cached --name-only)

echo "$staged" | grep -Eq \
  'crates/contracts/src/domain/|crates/backend/src/domain/|crates/backend/src/projections/|crates/backend/src/usecases/|crates/backend/src/data_schemes/|crates/backend/src/dashboards/|crates/backend/src/system/tasks/managers/|crates/backend/src/shared/analytics/(account|turnover)_registry\.rs|crates/backend/src/api/routes\.rs|tools/gen_architecture\.ps1' \
  || exit 0

echo "[pre-commit] Source map inputs changed — regenerating ARCHITECTURE.md..."
powershell.exe -NoProfile -ExecutionPolicy Bypass -File tools/gen_architecture.ps1
if [ $? -ne 0 ]; then
  echo "[pre-commit] WARNING: generator failed; committing without refreshing ARCHITECTURE.md." >&2
  exit 0
fi

git add ARCHITECTURE.md
exit 0
