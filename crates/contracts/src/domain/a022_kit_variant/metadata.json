{
  "$schema": "../../../schemas/metadata.schema.json",
  "schema_version": "1.0",

  "entity_type": "aggregate",
  "entity_name": "KitVariant",
  "entity_index": "a022",
  "collection_name": "kit_variant",
  "table_name": "a022_kit_variant",

  "ui": {
    "element_name": "Вариант комплектации",
    "element_name_en": "Kit Variant",
    "list_name": "Варианты комплектации",
    "list_name_en": "Kit Variants",
    "icon": "layers"
  },

  "ai": {
    "description": "Вариант комплектации номенклатуры из 1С:Управление торговлей. Описывает состав набора (kit) — какая номенклатура и в каком количестве входит в производимый товар. Используется для расчёта себестоимости комплектов.",
    "questions": [
      "Из каких компонентов состоит комплект?",
      "Какие товары входят в набор?",
      "Как рассчитать себестоимость набора?"
    ],
    "related": [
      "a004_nomenclature",
      "a001_connection_1c",
      "a021_production_output"
    ]
  },

  "fields": [
    {
      "name": "id",
      "rust_type": "KitVariantId",
      "field_type": "primitive",
      "source": "base",
      "ui": { "label": "ID", "label_en": "ID", "visible_in_list": false, "visible_in_form": false },
      "validation": { "required": true }
    },
    {
      "name": "code",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": { "label": "Код", "label_en": "Code", "visible_in_list": true, "visible_in_form": true, "column_width": 120 },
      "validation": { "required": true }
    },
    {
      "name": "description",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": { "label": "Наименование", "label_en": "Name", "visible_in_list": true, "visible_in_form": true, "column_width": 280 },
      "validation": { "required": true }
    },
    {
      "name": "owner_ref",
      "rust_type": "Option<String>",
      "field_type": "reference",
      "source": "specific",
      "ui": { "label": "Номенклатура-владелец", "label_en": "Owner Nomenclature", "visible_in_list": true, "visible_in_form": true, "column_width": 200 },
      "validation": { "required": false },
      "ref_aggregate": "a004_nomenclature",
      "ai_hint": "UUID производимой номенклатуры, для которой описан этот вариант комплектации."
    },
    {
      "name": "goods_json",
      "rust_type": "Option<String>",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Состав набора (JSON)", "label_en": "Goods (JSON)", "visible_in_list": false, "visible_in_form": false },
      "validation": { "required": false },
      "ai_hint": "JSON-массив [{nomenclature_ref, quantity}] — компоненты набора."
    },
    {
      "name": "connection_id",
      "rust_type": "String",
      "field_type": "reference",
      "source": "specific",
      "ui": { "label": "Подключение 1С", "label_en": "1C Connection", "visible_in_list": false, "visible_in_form": true },
      "validation": { "required": true },
      "ref_aggregate": "a001_connection_1c"
    }
  ],

  "access": {
    "scope_id": "a022_kit_variant",
    "operations": [
      { "id": "list",   "required_mode": "read" },
      { "id": "get",    "required_mode": "read" },
      { "id": "upsert", "required_mode": "all" },
      { "id": "delete", "required_mode": "all" }
    ]
  }
