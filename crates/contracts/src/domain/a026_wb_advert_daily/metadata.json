{
  "$schema": "../../../schemas/metadata.schema.json",
  "schema_version": "1.0",

  "entity_type": "aggregate",
  "entity_name": "WbAdvertDaily",
  "entity_index": "a026",
  "collection_name": "wb_advert_daily",
  "table_name": "a026_wb_advert_daily",

  "ui": {
    "element_name": "Статистика рекламы WB",
    "element_name_en": "WB Advert Daily",
    "list_name": "Статистика рекламы WB по дням",
    "list_name_en": "WB Advert Daily Stats",
    "icon": "megaphone"
  },

  "ai": {
    "description": "Ежедневная статистика рекламных кампаний Wildberries. Одна запись — один кабинет WB, одна дата и один advert_id. Содержит показы, клики, заказы, расходы на рекламу и JSON детализацию по товарам. Используется для анализа рекламных расходов, ДРР и связи рекламы с продажами через p911_wb_advert_by_items и General Ledger.",
    "questions": [
      "Сколько потрачено на рекламу WB за период?",
      "Какие рекламные кампании WB дали наибольшие расходы?",
      "Какой CTR, CPC и CR по рекламе WB за период?",
      "Какие рекламные расходы по кабинету WB?",
      "Какие товары получили рекламные показы и заказы?"
    ],
    "related": [
      "a006_connection_mp",
      "a002_organization",
      "a030_wb_advert_campaign",
      "p911_wb_advert_by_items"
    ]
  },

  "fields": [
    {
