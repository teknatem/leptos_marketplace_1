      "validation": { "required": true },
      "ai_hint": "UUID подключения магазина WB из a006_connection_mp. JOIN a006_connection_mp ON a040_wb_search_analytics_daily.connection_id = a006_connection_mp.id."
    },
    {
      "name": "organization_id",
      "rust_type": "String",
      "field_type": "aggregate_ref",
      "source": "specific",
      "ref_aggregate": "a002_organization",
      "ui": { "label": "Организация", "visible_in_list": false, "visible_in_form": false, "column_width": 220 },
      "validation": { "required": true },
      "ai_hint": "UUID организации из a002_organization."
    },
    {
      "name": "marketplace_id",
      "rust_type": "String",
      "field_type": "aggregate_ref",
      "source": "specific",
      "ref_aggregate": "a005_marketplace",
