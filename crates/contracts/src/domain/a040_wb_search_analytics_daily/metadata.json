      "ai_hint": "UUID маркетплейса из a005_marketplace."
    },
    {
      "name": "lines_count",
      "rust_type": "i32",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Позиций", "visible_in_list": true, "visible_in_form": false, "column_width": 90 },
      "validation": { "required": true },
      "ai_hint": "Количество товарных строк в JSON детализации lines_json."
    },
    {
      "name": "total_impressions",
      "rust_type": "i64",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Показы", "visible_in_list": true, "visible_in_form": false, "column_width": 110 },
      "validation": { "required": true },
      "ai_hint": "Суммарные показы в поиске на дату снимка."
    },
    {
      "name": "total_open_card",
      "rust_type": "i64",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Переходы", "visible_in_list": true, "visible_in_form": false, "column_width": 110 },
      "validation": { "required": true },
      "ai_hint": "Суммарные переходы в карточку из поиска на дату снимка."
    },
    {
      "name": "total_orders",
      "rust_type": "i64",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Заказы", "visible_in_list": true, "visible_in_form": false, "column_width": 100 },
      "validation": { "required": true },
      "ai_hint": "Суммарные заказы, атрибутированные поиску, на дату снимка."
    },
    {
      "name": "lines_json",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Строки JSON", "visible_in_list": false, "visible_in_form": false, "widget": "textarea" },
      "validation": { "required": true },
      "ai_hint": "JSON-массив детализации по товарам (одна запись = один nm_id на дату снимка). Ключи строки: nm_id, title, vendor_code, brand_name, subject_name, nomenclature_ref, metrics{impressions, open_card, ctr, add_to_cart, orders, avg_position, visibility}, top_queries[]{text, frequency, impressions, clicks, orders, avg_position}. Разворачивай через json_each и json_extract(j.value,'$.metrics.impressions')."
    },
    {
      "name": "fetched_at",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Загружено", "visible_in_list": false, "visible_in_form": false, "widget": "datetime", "column_width": 160 },
      "validation": { "required": true },
      "ai_hint": "Дата и время получения данных из WB Analytics API."
    }
  ],

  "access": {
