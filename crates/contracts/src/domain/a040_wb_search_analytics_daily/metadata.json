{
  "$schema": "../../../schemas/metadata.schema.json",
  "schema_version": "1.0",

  "entity_type": "aggregate",
  "entity_name": "WbSearchAnalyticsDaily",
  "entity_index": "a040",
  "collection_name": "wb_search_analytics_daily",
  "table_name": "a040_wb_search_analytics_daily",

  "ui": {
    "element_name": "Поисковая аналитика WB",
    "element_name_en": "WB Search Analytics",
    "list_name": "Поисковая аналитика WB по дням",
    "list_name_en": "WB Search Analytics Daily",
    "icon": "search"
  },

  "ai": {
    "description": "Ежедневные снимки поисковой аналитики Wildberries в разрезе номенклатуры (search-report / «Товары по контенту», подписка «Джем»): переходы в карточку из поиска, CTR, добавления в корзину, заказы, средняя позиция в выдаче, видимость (visibility, % показов в поиске), а также топ поисковых запросов на товар (текст, частотность, показы, клики, позиция). Данные снимаются только вперёд; один документ — один кабинет WB и одна дата. ВАЖНО: живой эндпоинт WB /table/details отдаёт только visibility (%), а не счётчик показов (impressions=0), поэтому a040 НЕ питает воронку p916 — связь удалена, show_free_count остаётся N/A.",
    "questions": [
      "Сколько показов у товара WB по дням?",
      "На какой позиции в выдаче стоит товар?",
      "Какие поисковые запросы приносят показы товару?",
      "Как менялась видимость карточки?",
      "CTR карточки в поиске по дням?"
    ],
    "related": [
      "a006_connection_mp",
      "a002_organization",
      "a007_marketplace_product",
      "a036_wb_sales_funnel_daily",
      "a037_wb_product_snapshot"
    ]
  },

  "fields": [
    {
      "name": "id",
      "rust_type": "WbSearchAnalyticsDailyId",
      "field_type": "primitive",
      "source": "base",
      "ui": { "label": "ID", "visible_in_list": false, "visible_in_form": false },
      "validation": { "required": true }
    },
    {
      "name": "code",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": { "label": "Код", "visible_in_list": true, "visible_in_form": false, "column_width": 160 },
      "validation": { "required": true },
      "ai_hint": "Внутренний код документа поисковой аналитики WB."
    },
    {
      "name": "description",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": { "label": "Описание", "visible_in_list": true, "visible_in_form": false, "column_width": 260 },
      "validation": { "required": true },
      "ai_hint": "Человекочитаемое описание документа: дата снимка."
    },
    {
      "name": "document_no",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Номер документа", "visible_in_list": false, "visible_in_form": false, "column_width": 160 },
      "validation": { "required": true },
      "ai_hint": "Технический номер документа снимка."
    },
    {
      "name": "document_date",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Дата", "visible_in_list": true, "visible_in_form": false, "widget": "date", "column_width": 120 },
      "validation": { "required": true },
      "ai_hint": "Дата снимка WB. Для периода используй document_date >= 'YYYY-MM-DD' AND document_date <= 'YYYY-MM-DD'."
    },
    {
      "name": "connection_id",
      "rust_type": "String",
      "field_type": "aggregate_ref",
      "source": "specific",
      "ref_aggregate": "a006_connection_mp",
