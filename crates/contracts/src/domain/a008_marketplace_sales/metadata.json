      "validation": { "required": true },
      "ref_aggregate": "a006_connection_mp"
    },
    {
      "name": "organization_id",
      "rust_type": "String",
      "field_type": "reference",
      "source": "specific",
      "ui": { "label": "Организация", "label_en": "Organization", "visible_in_list": false, "visible_in_form": true },
      "validation": { "required": true },
      "ref_aggregate": "a002_organization"
    },
    {
      "name": "marketplace_id",
      "rust_type": "String",
      "field_type": "reference",
      "source": "specific",
