      "validation": { "required": true },
      "ref_aggregate": "a005_marketplace"
    },
    {
      "name": "product_id",
      "rust_type": "String",
      "field_type": "reference",
      "source": "specific",
      "ui": { "label": "Товар", "label_en": "Product", "visible_in_list": true, "visible_in_form": true, "column_width": 200 },
      "validation": { "required": true },
      "ref_aggregate": "a007_marketplace_product"
    },
    {
      "name": "quantity",
      "rust_type": "i32",
      "field_type": "primitive",
