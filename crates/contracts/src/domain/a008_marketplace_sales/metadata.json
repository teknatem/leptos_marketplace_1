    {
      "name": "operation_type",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": { "label": "Тип операции", "label_en": "Operation Type", "visible_in_list": true, "visible_in_form": true, "column_width": 130 },
      "validation": { "required": true },
      "ai_hint": "Например: sale, return, commission."
