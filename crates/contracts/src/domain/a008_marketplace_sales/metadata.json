{
  "$schema": "../../../schemas/metadata.schema.json",
  "schema_version": "1.0",

  "entity_type": "aggregate",
  "entity_name": "MarketplaceSales",
  "entity_index": "a008",
  "collection_name": "marketplace_sales",
  "table_name": "a008_marketplace_sales",

  "ui": {
    "element_name": "Продажа маркетплейса",
