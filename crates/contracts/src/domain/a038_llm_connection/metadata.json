{
  "$schema": "../../../schemas/metadata.schema.json",
  "schema_version": "1.0",
  "entity_type": "aggregate",
  "entity_name": "LlmConnection",
  "entity_index": "a038",
  "collection_name": "llm_connection",
  "table_name": "a038_llm_connection",
  "ui": {
    "element_name": "Подключение LLM",
    "element_name_en": "LLM Connection",
    "list_name": "Подключения LLM",
    "list_name_en": "LLM Connections",
    "icon": "plug-connected"
  },
  "ai": {
    "description": "Подключение к провайдеру LLM (OpenAI, OpenRouter). Содержит API-ключ, эндпоинт, параметры модели (temperature, max_tokens), системный промпт и курируемый список разрешённых моделей (allowed_models). Чат работает через одно подключение и переключает модель в пределах allowed_models.",
    "questions": [
      "Какие LLM подключения настроены?",
      "Как добавить подключение OpenRouter?",
      "Какие модели разрешены для подключения?",
      "Как изменить список моделей подключения?"
    ],
    "related": [
      "a018_llm_chat",
      "a019_llm_artifact"
    ]
  },
  "fields": [
    {
      "name": "id",
      "rust_type": "LlmConnectionId",
      "field_type": "primitive",
      "source": "base",
      "ui": {
        "label": "ID",
        "label_en": "ID",
        "visible_in_list": false,
        "visible_in_form": false
      },
      "validation": {
        "required": true
      }
    },
    {
      "name": "code",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": {
        "label": "Код",
        "label_en": "Code",
        "placeholder": "OPENROUTER-MAIN",
        "hint": "Уникальный код подключения",
        "visible_in_list": true,
        "visible_in_form": true,
        "column_width": 150
      },
      "validation": {
        "required": true,
        "max_length": 50
      }
    },
    {
      "name": "description",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": {
        "label": "Наименование",
        "label_en": "Name",
        "placeholder": "OpenRouter основное подключение",
        "hint": "Описательное название подключения",
        "visible_in_list": true,
        "visible_in_form": true,
        "column_width": 250
      },
      "validation": {
        "required": true,
        "min_length": 3,
        "max_length": 255
      }
    },
    {
      "name": "comment",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "base",
      "ui": {
        "label": "Комментарий",
        "label_en": "Comment",
        "placeholder": "Используется для аналитики продаж",
        "hint": "Произвольный комментарий",
        "visible_in_list": false,
        "visible_in_form": true,
        "widget": "textarea"
      },
      "validation": {
        "required": false,
        "max_length": 1000
      }
    },
    {
      "name": "provider_type",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Провайдер",
        "label_en": "Provider",
        "hint": "Тип провайдера LLM",
        "visible_in_list": true,
        "visible_in_form": true,
        "widget": "select",
        "column_width": 120
      },
      "validation": {
        "required": true
      },
      "ai_hint": "Реально поддерживаемые провайдеры: OpenAI (GPT), OpenRouter (кросс-вендорный OpenAI-совместимый роутинг), DeepSeek (нативный OpenAI-совместимый API)"
    },
    {
      "name": "api_endpoint",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "API Endpoint",
        "label_en": "API Endpoint",
        "placeholder": "https://openrouter.ai/api/v1",
        "hint": "URL эндпоинта API провайдера",
        "visible_in_list": false,
        "visible_in_form": true,
        "column_width": 300
      },
      "validation": {
        "required": true,
        "max_length": 500,
        "pattern": "^https?://.+",
        "custom_error": "URL должен начинаться с http:// или https://"
      },
      "ai_hint": "OpenAI: https://api.openai.com/v1, OpenRouter: https://openrouter.ai/api/v1, DeepSeek: https://api.deepseek.com"
    },
    {
      "name": "api_key",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "API Ключ",
        "label_en": "API Key",
        "placeholder": "sk-...",
        "hint": "API ключ для аутентификации",
        "visible_in_list": false,
        "visible_in_form": true,
        "widget": "password"
      },
      "validation": {
        "required": true,
        "max_length": 500
      },
      "ai_hint": "Хранится в зашифрованном виде."
    },
    {
      "name": "model_name",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Модель по умолчанию",
        "label_en": "Default Model",
        "placeholder": "openai/gpt-4o",
        "hint": "Модель по умолчанию для новых чатов",
        "visible_in_list": true,
        "visible_in_form": true,
        "column_width": 150
      },
      "validation": {
        "required": true,
        "max_length": 100
      },
      "ai_hint": "Должна входить в allowed_models. OpenAI: gpt-4o. OpenRouter: openai/gpt-4o, anthropic/claude-sonnet-5, deepseek/deepseek-chat. DeepSeek (нативно): deepseek-chat, deepseek-reasoner"
    },
    {
      "name": "available_models",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Доступные модели",
        "label_en": "Available Models",
        "hint": "JSON список моделей из API (кэш fetch-models)",
        "visible_in_list": false,
        "visible_in_form": false,
        "widget": "textarea"
      },
      "validation": {
        "required": false
      },
      "ai_hint": "JSON массив объектов с полями id, created, owned_by. Загружается из /v1/models API провайдера."
    },
    {
      "name": "allowed_models",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Разрешённые модели",
        "label_en": "Allowed Models",
        "hint": "Курируемый короткий список моделей (JSON-массив id)",
        "visible_in_list": false,
        "visible_in_form": true,
        "widget": "textarea"
      },
      "validation": {
        "required": false
      },
      "ai_hint": "JSON массив model_id — подмножество available_models. Только эти модели можно выбрать в чате. Держите 3-8 технически совместимых и целесообразных моделей."
    },
    {
      "name": "temperature",
      "rust_type": "f64",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Temperature",
        "label_en": "Temperature",
        "placeholder": "0.7",
        "hint": "Креативность ответов (0.0-2.0)",
        "visible_in_list": false,
        "visible_in_form": true
      },
      "validation": {
        "required": true,
        "min": 0.0,
        "max": 2.0
      },
      "ai_hint": "0.0 - детерминированно, 1.0 - сбалансированно, 2.0 - максимально креативно"
    },
    {
      "name": "max_tokens",
      "rust_type": "i32",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Max Tokens",
        "label_en": "Max Tokens",
        "placeholder": "4096",
        "hint": "Максимальная длина ответа",
        "visible_in_list": false,
        "visible_in_form": true
      },
      "validation": {
        "required": true,
        "min": 256,
        "max": 128000
      },
      "ai_hint": "GPT-4o поддерживает до 128k токенов"
    },
    {
      "name": "system_prompt",
      "rust_type": "String",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Системный промпт",
        "label_en": "System Prompt",
        "placeholder": "Ты аналитик данных маркетплейсов...",
        "hint": "Базовая инструкция (персона)",
        "visible_in_list": false,
        "visible_in_form": true,
        "widget": "textarea"
      },
      "validation": {
        "required": false,
        "max_length": 5000
      },
      "ai_hint": "Определяет роль и поведение. Если пусто — используется role-agnostic core-промпт из skills."
    },
    {
      "name": "is_primary",
      "rust_type": "bool",
      "field_type": "primitive",
      "source": "specific",
      "ui": {
        "label": "Основное",
        "label_en": "Primary",
        "hint": "Использовать по умолчанию",
        "visible_in_list": true,
        "visible_in_form": true,
        "widget": "checkbox",
        "column_width": 100
      },
      "validation": {
        "required": false
      },
      "ai_hint": "Только одно подключение может быть основным. При установке флага автоматически снимается с других."
    }
  ],

  "access": {
    "scope_id": "a038_llm_connection",
    "operations": [
      { "id": "list",   "required_mode": "read" },
      { "id": "get",    "required_mode": "read" },
      { "id": "upsert", "required_mode": "all" },
      { "id": "delete", "required_mode": "all" }
    ]
  }
}
