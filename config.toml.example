# Marketplace Integrator Configuration
# This file configures database path and other settings
#
# IMPORTANT: Place this file next to backend.exe and rename it to config.toml

[database]
# Database file path
# 
# WINDOWS USERS: Use forward slashes (/) instead of backslashes (\)
# Windows accepts both types of slashes, but TOML requires special
# handling for backslashes in double-quoted strings.
#
# ✓ CORRECT (forward slashes):
# path = "C:/Users/username/Desktop/MPI/data/app.db"
#
# ✓ ALSO CORRECT (relative path):
# path = "data/app.db"
#
# ✓ ALSO CORRECT (double backslashes):
# path = "C:\\Users\\username\\Desktop\\MPI\\data\\app.db"
#
# ✓ ALSO CORRECT (single quotes for literal string):
# path = 'C:\Users\username\Desktop\MPI\data\app.db'
#
# ❌ WRONG (will cause parse error):
# path = "C:\Users\username\Desktop\MPI\data\app.db"

# Example 1: Relative path (database next to exe)
path = "data/app.db"

# Example 2: Absolute path on Windows
# path = "C:/Users/udv/Desktop/MPI/data/app.db"

# Example 3: Absolute path on Linux/Mac
# path = "/var/lib/marketplace/app.db"

# The directory will be created automatically if it doesn't exist

[scheduled_tasks]
enabled = false

[llm]
# Директория с Obsidian-совместимыми MD-файлами базы знаний.
# Относительный путь разрешается от директории бинарника.
knowledge_base_path = "E:/dev/rust/2/data/knowledge"

[external_api]
# Статический API-ключ для внешних интеграций (например, 1С).
# Передаётся в заголовке: X-Api-Key: <значение>
# Если пустая строка — внешний API отключён (возвращает 503).
api_key = ""

[ui]
# Смещение часового пояса для отображения времени в интерфейсе.
# Константа дублируется в frontend/src/shared/tz.rs (TZ_OFFSET_HOURS).
timezone_offset_hours = 3

[s3]
# Manual S3 file manager. Keep disabled until bucket and credentials are configured.
enabled = false
endpoint = "https://storage.yandexcloud.net"
region = "ru-central1"
bucket = ""
access_key_id = ""
secret_access_key = ""
max_upload_mb = 512
